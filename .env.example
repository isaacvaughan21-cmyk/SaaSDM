# Copy this file to .env.local for local dev, and to .env.production for the
# deployed build. These values are safe to expose in a static site — the
# anon key only allows what your Row-Level Security policies permit.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
